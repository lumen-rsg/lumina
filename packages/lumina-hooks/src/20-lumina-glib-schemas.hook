[Trigger]
Type = File
Operation = Install
Operation = Upgrade
Operation = Remove
Target = usr/share/glib-2.0/schemas/*

[Action]
Description = Compiling GSettings XML schema files...
When = PostTransaction
Exec = /bin/sh -c "command -v glib-compile-schemas >/dev/null && glib-compile-schemas /usr/share/glib-2.0/schemas"