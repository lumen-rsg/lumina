pkgname=lumina-hooks
pkgver=1.0.0
pkgrel=1
pkgdesc="Essential distro-level ALPM hooks for Lumina OS"
arch=('any')
license=('GPL3')
depends=('bash' 'coreutils')
source=(
    "10-lumina-sysusers.hook"
    "10-lumina-tmpfiles.hook"
    "10-lumina-daemon-reload.hook"
    "20-lumina-fontconfig.hook"
    "20-lumina-glib-schemas.hook"
    "20-lumina-desktop-db.hook"
    "20-lumina-mime-db.hook"
    "20-lumina-hwdb.hook"
    "30-lumina-gtk-icon-cache.hook"
    "lumina-gtk-icon-cache.sh"
)
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
    install -dm755 "$pkgdir/usr/share/libalpm/hooks"
    install -dm755 "$pkgdir/usr/share/libalpm/scripts"
    install -m644 "$srcdir"/*.hook "$pkgdir/usr/share/libalpm/hooks/"
    install -m755 "$srcdir/lumina-gtk-icon-cache.sh" "$pkgdir/usr/share/libalpm/scripts/lumina-gtk-icon-cache"
}