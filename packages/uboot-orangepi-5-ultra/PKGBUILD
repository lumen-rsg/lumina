pkgname=uboot-orangepi-5-ultra
pkgver=2025.10
pkgrel=1
pkgdesc="Mainline U-Boot and ATF for Orange Pi 5 Ultra"
arch=('aarch64')
license=('GPL2')
makedepends=('git' 'aarch64-linux-gnu-gcc' 'bison' 'flex' 'python' 'swig' 'python-setuptools' 'dtc' 'bc')

# We need three repositories: 
# 1. Trusted Firmware-A (ATF)
# 2. Rockchip binaries (for DDR init)
# 3. Mainline U-Boot
source=(
    "atf::git+https://github.com/ARM-software/arm-trusted-firmware.git"
    "rkbin::git+https://github.com/rockchip-linux/rkbin.git"
    "uboot::git+https://source.denx.de/u-boot/u-boot.git"
)
sha256sums=('SKIP' 'SKIP' 'SKIP')

build() {
    export CROSS_COMPILE=aarch64-linux-gnu-
    
    # 1. Build ARM Trusted Firmware (TF-A)
    msg2 "Building TF-A for RK3588..."
    cd "$srcdir/atf"
    make realclean
    make PLAT=rk3588 bl31
    
    # Export BL31 path for U-Boot to pick up
    export BL31="$srcdir/atf/build/rk3588/release/bl31/bl31.elf"
    
    # Export Rockchip DDR blob
    export ROCKCHIP_TPL="$srcdir/rkbin/bin/rk35/rk3588_ddr_lp4_2112MHz_lp5_2400MHz_v1.19.bin"

    # 2. Build U-Boot
    msg2 "Building Mainline U-Boot..."
    cd "$srcdir/uboot"
    make distclean
    
    # Use the appropriate defconfig (Mainline U-Boot has added OPi 5 support)
    make orangepi-5-plus-rk3588_defconfig
    
    # Build the final images
    make -j$(nproc)
}

package() {
    install -dm755 "$pkgdir/boot/extlinux"
    install -dm755 "$pkgdir/usr/share/uboot/orangepi-5-ultra"
    
    cd "$srcdir/uboot"
    
    # These are the two critical files that will be flashed to the disk
    install -m644 idbloader.img "$pkgdir/usr/share/uboot/orangepi-5-ultra/"
    install -m644 u-boot.itb "$pkgdir/usr/share/uboot/orangepi-5-ultra/"
    
    # Provide a helper script to flash the bootloader
    cat << 'EOF' > "$pkgdir/usr/share/uboot/orangepi-5-ultra/flash-bootloader.sh"
#!/bin/bash
if[ -z "$1" ]; then
    echo "Usage: $0 /dev/nvme0n1 (or /dev/mmcblk0)"
    exit 1
fi
echo "Flashing idbloader to sector 64..."
dd if=idbloader.img of=$1 seek=64 conv=notrunc status=progress
echo "Flashing u-boot.itb to sector 16384..."
dd if=u-boot.itb of=$1 seek=16384 conv=notrunc status=progress
sync
echo "Done."
EOF
    chmod +x "$pkgdir/usr/share/uboot/orangepi-5-ultra/flash-bootloader.sh"
}