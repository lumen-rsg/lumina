pkgname=lumina-kernel-manager
pkgver=1.0.0
pkgrel=1
pkgdesc="Interactive kernel manager and automation hook for Lumina OS"
arch=('any')
license=('GPL3')
depends=('bash' 'coreutils' 'dracut' 'systemd' 'util-linux')
source=(
    "lumina-kernel"
    "90-lumina-kernel.hook"
)
sha256sums=('SKIP' 'SKIP')

package() {
    install -Dm755 "$srcdir/lumina-kernel" "$pkgdir/usr/bin/lumina-kernel"
    install -Dm644 "$srcdir/90-lumina-kernel.hook" "$pkgdir/usr/share/libalpm/hooks/90-lumina-kernel.hook"
}