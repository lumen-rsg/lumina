# Maintainer: Lumina OS Team

pkgbase=lumina-kernel-rk3588
pkgver=6.19.6
pkgrel=1
pkgdesc='Mainline Linux Kernel for RK3588 (Orange Pi 5 Ultra)'
url='https://kernel.org'
arch=(aarch64)
license=(GPL-2.0-only)

makedepends=(
  bc
  cpio
  gettext
  libelf
  pahole
  perl
  python
  tar
  xz
  make
  bison
  flex
)

options=(
  !debug
  !strip
)

_srcname=linux-$pkgver
source=("https://cdn.kernel.org/pub/linux/kernel/v6.x/${_srcname}.tar.xz")
sha256sums=('SKIP')

export KBUILD_BUILD_HOST=lumina
export KBUILD_BUILD_USER=$pkgbase
export KBUILD_BUILD_TIMESTAMP="$(date -Ru${SOURCE_DATE_EPOCH:+d @$SOURCE_DATE_EPOCH})"

prepare() {
  cd "$_srcname"

  # Prevent host makepkg/Aurora flags from leaking into the cross-compiler
  # unset CFLAGS CXXFLAGS CPPFLAGS LDFLAGS

  echo "Setting version..."
  echo "-$pkgrel" > localversion.10-pkgrel
  echo "${pkgbase#linux}" > localversion.20-pkgname

  echo "Setting base config (defconfig)..."
  make ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- defconfig

  echo "Applying Lumina & RK3588 Customizations..."
  
  # 1. Branding
  scripts/config --set-str LOCALVERSION "-lumina-rk3588"
  scripts/config --set-str DEFAULT_HOSTNAME "lumina-os"

  # 2. Disable BTF (Fixes the libbpf/pahole ELF section errors)
  scripts/config --disable CONFIG_DEBUG_INFO_BTF
  scripts/config --disable CONFIG_DEBUG_INFO_BTF_MODULES

  # 3. Strip heavy PCIe desktop GPUs to save massive compile time
  scripts/config --disable CONFIG_DRM_NOUVEAU
  scripts/config --disable CONFIG_DRM_AMDGPU
  scripts/config --disable CONFIG_DRM_RADEON

  # 4. Enable specific RK3588 / Orange Pi 5 Hardware
  scripts/config --enable CONFIG_ARCH_ROCKCHIP
  scripts/config --enable CONFIG_DRM_PANTHOR
  scripts/config --enable CONFIG_VIDEO_ROCKCHIP_VDPU
  scripts/config --module CONFIG_VIDEO_HANTRO

  echo "Regenerating config..."
  make ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- olddefconfig

  make ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- -s kernelrelease > version
  echo "Prepared $pkgbase version $(<version)"
}

build() {
  cd "$_srcname"
  
  # Ensure flags stay unset
  # unset CFLAGS CXXFLAGS CPPFLAGS LDFLAGS
  
  echo "Building Kernel Image and Modules..."
  make ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- all -j$(nproc)
}

_package() {
  pkgdesc="The $pkgdesc kernel and modules"
  depends=(
    coreutils
    initramfs
    kmod
  )
  provides=(linux)
  conflicts=(linux)

  cd "$_srcname"
  # unset CFLAGS CXXFLAGS CPPFLAGS LDFLAGS

  local modulesdir="$pkgdir/usr/lib/modules/$(<version)"

  echo "Installing boot image..."
  install -Dm644 arch/arm64/boot/Image "$modulesdir/vmlinuz"

  echo "$pkgbase" | install -Dm644 /dev/stdin "$modulesdir/pkgbase"

  echo "Installing modules..."
  make ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- \
    INSTALL_MOD_PATH="$pkgdir/usr" INSTALL_MOD_STRIP=1 DEPMOD=/doesnt/exist modules_install

  echo "Installing Device Trees..."
  make ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- \
    INSTALL_DTBS_PATH="$pkgdir/boot/dtbs/rockchip" dtbs_install

  rm -f "$modulesdir"/build
  rm -f "$modulesdir"/source
}

_package-headers() {
  pkgdesc="Headers and scripts for building modules for the $pkgdesc kernel"
  depends=(pahole)
  provides=(linux-headers)
  conflicts=(linux-headers)

  cd "$_srcname"
  # unset CFLAGS CXXFLAGS CPPFLAGS LDFLAGS

  local builddir="$pkgdir/usr/lib/modules/$(<version)/build"

  echo "Installing build files..."
  install -Dt "$builddir" -m644 .config Makefile Module.symvers System.map \
    localversion.* version vmlinux

  install -Dt "$builddir/kernel" -m644 kernel/Makefile
  install -Dt "$builddir/arch/arm64" -m644 arch/arm64/Makefile
  cp -t "$builddir" -a scripts
  ln -srt "$builddir" "$builddir/scripts/gdb/vmlinux-gdb.py" || true

  echo "Installing headers..."
  cp -t "$builddir" -a include
  cp -t "$builddir/arch/arm64" -a arch/arm64/include
  install -Dt "$builddir/arch/arm64/kernel" -m644 arch/arm64/kernel/asm-offsets.s

  # Install required subsystem headers
  install -Dt "$builddir/drivers/md" -m644 drivers/md/*.h || true
  install -Dt "$builddir/net/mac80211" -m644 net/mac80211/*.h || true

  echo "Installing KConfig files..."
  find . -name 'Kconfig*' -exec install -Dm644 {} "$builddir/{}" \;

  echo "Removing unneeded architectures..."
  for arch in "$builddir"/arch/*/; do
    [[ $arch = */arm64/ ]] && continue
    rm -r "$arch"
  done

  echo "Removing documentation..."
  rm -rf "$builddir/Documentation"
  find -L "$builddir" -type l -printf 'Removing %P\n' -delete
  find "$builddir" -type f -name '*.o' -printf 'Removing %P\n' -delete

  echo "Adding symlink..."
  mkdir -p "$pkgdir/usr/src"
  ln -sr "$builddir" "$pkgdir/usr/src/$pkgbase"
}

pkgname=(
  "$pkgbase"
  "$pkgbase-headers"
)

for _p in "${pkgname[@]}"; do
  eval "package_$_p() {
    $(declare -f "_package${_p#$pkgbase}")
    _package${_p#$pkgbase}
  }"
done