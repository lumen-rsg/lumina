#!/bin/bash
set -e

# ==============================================================================
# LUMINA GPU AUTOCONFIGURATOR
# ==============================================================================
CYAN='\033[0;36m'
GREEN='\033[0;32m'
NC='\033[0m'

if [ "$EUID" -ne 0 ]; then
    echo "Error: Must be run as root."
    exit 1
fi

echo -e "${CYAN}:: Scanning PCI bus for display controllers...${NC}"

HAS_NVIDIA=0
HAS_AMD=0
HAS_INTEL=0

# Read VGA and 3D controllers
while read -r line; do
    if echo "$line" | grep -qi "nvidia"; then HAS_NVIDIA=1; fi
    if echo "$line" | grep -qi -e "advanced micro devices" -e "amd" -e "ati"; then HAS_AMD=1; fi
    if echo "$line" | grep -qi "intel"; then HAS_INTEL=1; fi
done < <(lspci | grep -iE 'vga|3d|display')

PKGS=()

if [ $HAS_NVIDIA -eq 1 ]; then
    echo -e "${GREEN}✔ NVIDIA GPU detected.${NC}"
    # Use open DKMS driver by default for modern cards, plus Wayland EGL
    PKGS+=('nvidia-open-dkms' 'nvidia-utils' 'egl-wayland')
    
    echo -e "${CYAN}:: Configuring NVIDIA for Wayland...${NC}"
    # 1. Blacklist nouveau
    mkdir -p /etc/modprobe.d
    echo "blacklist nouveau" > /etc/modprobe.d/nouveau-blacklist.conf
    echo "options nouveau modeset=0" >> /etc/modprobe.d/nouveau-blacklist.conf
    
    # 2. Enable DRM modesetting (Required for Hyprland)
    echo "options nvidia-drm modeset=1 fbdev=1" > /etc/modprobe.d/nvidia-wayland.conf
fi

if [ $HAS_AMD -eq 1 ]; then
    echo -e "${GREEN}✔ AMD GPU detected.${NC}"
    PKGS+=('mesa' 'vulkan-radeon' 'libva-mesa-driver' 'mesa-vdpau')
fi

if [ $HAS_INTEL -eq 1 ]; then
    echo -e "${GREEN}✔ INTEL GPU detected.${NC}"
    PKGS+=('mesa' 'vulkan-intel' 'intel-media-driver')
fi

if [ ${#PKGS[@]} -eq 0 ]; then
    echo -e "${CYAN}:: No dedicated GPU found (VM or exotic hardware). Defaulting to Mesa.${NC}"
    PKGS+=('mesa')
fi

echo -e "${CYAN}:: Installing required driver packages...${NC}"
# Use the Aurora CLI directly
au install -y "${PKGS[@]}"

echo -e "${GREEN}✔ GPU driver setup complete.${NC}"