pkgname=aurora
pkgver=1.0.0
pkgrel=1
pkgdesc="The ultra-fast, NativeAOT package manager and build system for Lumina OS"
arch=('x86_64')
url="https://github.com/lumen-rsg/aurora"
license=('GPL3')

# Runtime dependencies: Everything Aurora calls out to via Process.Start
depends=(
    'bash'
    'tar'
    'zstd'
    'fakeroot'
    'gnupg'
    'coreutils'
    'glibc'
)

# Build dependencies: Required for NativeAOT compilation
makedepends=(
    'dotnet-sdk'
    'clang'
    'zlib'
)

source=("git+https://github.com/lumen-rsg/aurora.git#branch=main")
sha256sums=('SKIP')

build() {
    cd "$pkgname"
    
    # Opt out of .NET telemetry for a cleaner build
    export DOTNET_CLI_TELEMETRY_OPTOUT=1
    
    msg2 "Building Aurora CLI (au)..."
    dotnet publish Aurora.CLI -c Release -r linux-x64 /p:PublishAot=true -o "$srcdir/out/cli"

    msg2 "Building Aurora RepoTool (au-repotool)..."
    dotnet publish Aurora.RepoTool -c Release -r linux-x64 /p:PublishAot=true -o "$srcdir/out/repotool"

    msg2 "Building Lumina Installer..."
    dotnet publish Aurora.Installer -c Release -r linux-x64 /p:PublishAot=true -o "$srcdir/out/installer"
}

package() {
    cd "$pkgname"
    install -dm755 "$pkgdir/usr/bin"
    install -dm755 "$pkgdir/usr/lib"
    install -dm755 "$pkgdir/etc/aurora"
    install -dm755 "$pkgdir/var/lib/aurora"
    install -dm755 "$pkgdir/var/cache/aurora"
    install -m755 "$srcdir/out/cli/au" "$pkgdir/usr/bin/au"
    install -m755 "$srcdir/out/repotool/au-repotool" "$pkgdir/usr/bin/au-repotool"
    
    if [[ -f "$srcdir/out/installer/lumina-installer" ]]; then
        install -m755 "$srcdir/out/installer/lumina-installer" "$pkgdir/usr/bin/lumina-installer"
    else
        install -m755 "$srcdir/out/installer/Aurora.Installer" "$pkgdir/usr/bin/lumina-installer"
    fi

    if [[ -f "$srcdir/out/cli/libe_sqlite3.so" ]]; then
        install -m755 "$srcdir/out/cli/libe_sqlite3.so" "$pkgdir/usr/lib/libe_sqlite3.so"
    fi

    # Create Default Repository Configuration
    msg2 "Generating default repolist..."
    cat <<EOF > "$pkgdir/etc/aurora/repolist"
# Lumina OS Default Repositories

[core]
name = Lumina Core
url = https://packages.lumina.1t.ru/core
enabled = true

[extra]
name = Lumina Extra
url = https://packages.lumina.1t.ru/extra
enabled = true

[lumen]
name = Lumen
url = https://packages.lumina.1t.ru/lumen
enabled = true
EOF

    chmod 644 "$pkgdir/etc/aurora/repolist"
}