pkgname=lumina-core
pkgver=1.0.0
pkgrel=1
pkgdesc="The foundational components of Lumina OS"
arch=('any')
license=('GPL3')

depends=(
    # Base requirements
    'base'
    'linux'
    'linux-firmware'
    
    # Boot & Init
    'systemd'
    'systemd-sysvcompat'
    'dracut'
    'efibootmgr'
    
    # Lumina Package Management
    'aurora'
    'lumina-hooks'
    'lumina-kernel-manager'
    
    # Critical System Utilities
    'sudo'
    'nano'          # Failsafe editor
    'less'
    'bash-completion'
    'man-db'
    'man-pages'
    
    # Filesystem & Storage tools
    'e2fsprogs'
    'dosfstools'    # For EFI partitions
    'mtools'
    'ntfs-3g'
    'parted'
    'smartmontools'
)

package() {
    install -dm755 "$pkgdir/usr/share/doc/$pkgname"
    echo "Lumina Core System" > "$pkgdir/usr/share/doc/$pkgname/README.md"
}